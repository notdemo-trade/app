{
	"name": "@repo/data-ops",
	"version": "1.0.0",
	"description": "Manage auth, database, schemas, and queries",
	"exports": {
		"./auth/*": {
			"types": "./dist/auth/*.d.ts",
			"default": "./dist/auth/*.js"
		},
		"./database/*": {
			"types": "./dist/database/*.d.ts",
			"default": "./dist/database/*.js"
		},
		"./drizzle/*": {
			"types": "./dist/drizzle/*.d.ts",
			"default": "./dist/drizzle/*.js"
		},
		"./health": {
			"types": "./dist/health/index.d.ts",
			"default": "./dist/health/index.js"
		},
		"./api-token": {
			"types": "./dist/api-token/index.d.ts",
			"default": "./dist/api-token/index.js"
		},
		"./credential": {
			"types": "./dist/credential/index.d.ts",
			"default": "./dist/credential/index.js"
		},
		"./trading-config": {
			"types": "./dist/trading-config/index.d.ts",
			"default": "./dist/trading-config/index.js"
		},
		"./ta-config": {
			"types": "./dist/ta-config/index.d.ts",
			"default": "./dist/ta-config/index.js"
		},
		"./providers/alpaca": {
			"types": "./dist/providers/alpaca/index.d.ts",
			"default": "./dist/providers/alpaca/index.js"
		},
		"./portfolio": {
			"types": "./dist/portfolio/index.d.ts",
			"default": "./dist/portfolio/index.js"
		},
		"./signal": {
			"types": "./dist/signal/index.d.ts",
			"default": "./dist/signal/index.js"
		},
		"./analysis": {
			"types": "./dist/analysis/index.d.ts",
			"default": "./dist/analysis/index.js"
		},
		"./agents/*": {
			"types": "./dist/agents/*.d.ts",
			"default": "./dist/agents/*.js"
		},
		"./providers/technicals": {
			"types": "./dist/providers/technicals/index.d.ts",
			"default": "./dist/providers/technicals/index.js"
		},
		"./providers/llm": {
			"types": "./dist/providers/llm/index.d.ts",
			"default": "./dist/providers/llm/index.js"
		},
		"./llm-analysis": {
			"types": "./dist/llm-analysis/index.d.ts",
			"default": "./dist/llm-analysis/index.js"
		},
		"./debate-persona": {
			"types": "./dist/debate-persona/index.d.ts",
			"default": "./dist/debate-persona/index.js"
		},
		"./notification-settings": {
			"types": "./dist/notification-settings/index.d.ts",
			"default": "./dist/notification-settings/index.js"
		},
		"./telegram": {
			"types": "./dist/telegram/index.d.ts",
			"default": "./dist/telegram/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json --outDir ./dist && tsc-alias",
		"better-auth:generate": "mkdir -p src/drizzle && npx @better-auth/cli@latest generate --config ./config/auth.ts --output ./src/drizzle/auth-schema.ts",
		"drizzle:dev:generate": "dotenvx run -f .env.dev -- drizzle-kit generate --config drizzle-dev.config.ts",
		"drizzle:dev:migrate": "dotenvx run -f .env.dev -- drizzle-kit migrate --config drizzle-dev.config.ts",
		"drizzle:dev:pull": "dotenvx run -f .env.dev -- drizzle-kit pull --config drizzle-dev.config.ts",
		"drizzle:staging:generate": "dotenvx run -f .env.staging -- drizzle-kit generate --config drizzle-staging.config.ts",
		"drizzle:staging:migrate": "dotenvx run -f .env.staging -- drizzle-kit migrate --config drizzle-staging.config.ts",
		"drizzle:staging:pull": "dotenvx run -f .env.staging -- drizzle-kit pull --config drizzle-staging.config.ts",
		"drizzle:production:generate": "dotenvx run -f .env.production -- drizzle-kit generate --config drizzle-production.config.ts",
		"drizzle:production:migrate": "dotenvx run -f .env.production -- drizzle-kit migrate --config drizzle-production.config.ts",
		"drizzle:production:pull": "dotenvx run -f .env.production -- drizzle-kit pull --config drizzle-production.config.ts",
		"seed:dev": "dotenvx run -f .env.dev -- tsx src/database/seed/seed.ts",
		"seed:staging": "dotenvx run -f .env.staging -- tsx src/database/seed/seed.ts",
		"seed:production": "dotenvx run -f .env.production -- tsx src/database/seed/seed.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.14.0",
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.58",
		"workers-ai-provider": "^3.1.2",
		"@ai-sdk/deepseek": "^2.0.24",
		"@ai-sdk/google": "^3.0.43",
		"@ai-sdk/openai": "^3.0.41",
		"@ai-sdk/xai": "^3.0.67",
		"@neondatabase/serverless": "^1.0.2",
		"ai": "^6.0.116",
		"better-auth": "^1.4.18",
		"drizzle-orm": "^0.45.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260207.0",
		"drizzle-kit": "^0.31.9",
		"postgres": "^3.4.8",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
